# StoryEngine Configuration
# Copy to .env only if you need to override defaults.
# All settings below can be configured from the dashboard at http://localhost:3100/settings

# Ports
SE_PORT=8100
SE_FRONTEND_PORT=3100

# All other settings are configured via the web dashboard:
# - Ollama URL (where your LLM server is running)
# - Downloads path (where your video library is)
# - Whisper model, LLM model, scan interval, etc.
#
# To pre-configure via environment (optional):
# SE_OLLAMA_URL=http://192.168.1.50:11434
# SE_DOWNLOADS_DIR=/path/to/videos
# SE_LLM_MODEL=llama3.1:8b
# SE_WHISPER_MODEL=base

TZ=UTC
